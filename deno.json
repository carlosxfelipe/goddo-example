{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env src/index.ts",
    "start": "deno run --allow-net --allow-env src/index.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@goddo/core": "jsr:@goddo/core",
    "@goddo/html": "jsr:@goddo/html",
    "@goddo/openapi": "jsr:@goddo/openapi",
    "@goddo/llms-txt": "jsr:@goddo/llms-txt"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@goddo/html"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/node_modules",
    "bruno/"
  ]
}
