{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write --allow-ffi src/index.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --allow-ffi src/index.ts",
    "test": "deno test --allow-net --allow-read --allow-env --allow-write --allow-ffi",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "bench": "deno bench --allow-net --allow-read --allow-write --allow-ffi --allow-env benchmarks/",
    "bench:app": "deno bench --allow-net --allow-read --allow-write --allow-ffi --allow-env benchmarks/app.bench.ts",
    "coverage": "rm -rf cov/ && deno test --coverage=cov/ --allow-net --allow-read --allow-env --allow-write --allow-ffi && deno coverage cov/"
  },
  "minimumDependencyAge": 0,
  "imports": {
    "@goddo/core": "jsr:@goddo/core",
    "@goddo/html": "jsr:@goddo/html",
    "@goddo/openapi": "jsr:@goddo/openapi",
    "@goddo/llms-txt": "jsr:@goddo/llms-txt",
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@goddo/html"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/node_modules",
    "bruno/"
  ]
}
